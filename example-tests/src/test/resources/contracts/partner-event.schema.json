{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventId", "payload"],
  "properties": {
    "eventId": { "type": "string", "pattern": "^evt-" },
    "traceId": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": { "type": "string", "enum": ["accepted", "rejected"] },
        "amount": { "type": "number", "minimum": 0 }
      }
    }
  }
}
